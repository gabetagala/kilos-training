#!/bin/sh
# Kilos pre-commit gate. Keep it fast — this runs on every commit.
# Wired via the "prepare" npm script (core.hooksPath = .githooks).

# Lint (Biome). Blocks the commit on errors.
npm run lint || {
  echo "✗ Biome lint failed — fix the errors above, or run 'npm run check' to auto-fix what's safe."
  exit 1
}

# Design-system guardrail (12px text floor / token scale) is added in
# Batch 5 of FOUNDATION-SETUP.md. Uncomment when scripts/check-design-system.mjs lands:
# npm run lint:design || { echo "✗ Design-system check failed."; exit 1; }

exit 0
