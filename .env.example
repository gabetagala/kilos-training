# Copy this file to .env.local and fill in your Supabase values.
# Never commit .env.local — it's in .gitignore.
# These same keys go into Vercel → Settings → Environment Variables.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Formspree form ID — get it free at formspree.io
# Paste only the ID part (e.g. xpznkqwb), NOT the full URL.
VITE_FORMSPREE_ID=your-form-id-here
